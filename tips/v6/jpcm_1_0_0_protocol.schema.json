{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jmcp.dev/schemas/jpcm/1.0.0/jpcm-envelope.schema.json",
  "title": "JPCM-1.0.0 Control Envelope and Protocol Object Schema",
  "description": "Versioned schema for the Joint Process Control Messaging protocol used by the Joint Master Control Plane. This schema validates the canonical envelope and embedded control objects for tasks, leases, tools, data, evidence, attention, voice, memory, self-improvement, and automated tool building.",
  "type": "object",
  "required": [
    "jpcm_version",
    "message_id",
    "message_type",
    "subject",
    "issued_at",
    "producer",
    "trace",
    "delivery",
    "risk",
    "schema",
    "payload_hash",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "jpcm_version": {
      "const": "1.0.0"
    },
    "message_id": {
      "type": "string",
      "pattern": "^(urn:jpcm:msg:)?[A-Za-z0-9._:-]{16,128}$",
      "description": "Globally unique UUIDv7, ULID, or urn:jpcm:msg value."
    },
    "message_type": {
      "$ref": "#/$defs/MessageType"
    },
    "subject": {
      "type": "string",
      "pattern": "^jpcm\\.[a-z0-9][a-z0-9_.-]{1,240}$"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "not_before": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "default": null
    },
    "producer": {
      "$ref": "#/$defs/Principal"
    },
    "audience": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PrincipalRef"
      },
      "default": []
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "repo_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "trace": {
      "$ref": "#/$defs/TraceContext"
    },
    "delivery": {
      "$ref": "#/$defs/DeliverySemantics"
    },
    "risk": {
      "$ref": "#/$defs/RiskContext"
    },
    "data_classification": {
      "$ref": "#/$defs/DataClassification"
    },
    "policy_context": {
      "$ref": "#/$defs/PolicyContext"
    },
    "lease_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "context_contract_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema": {
      "$ref": "#/$defs/SchemaRef"
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "payload": {
      "$ref": "#/$defs/Payload"
    },
    "redaction": {
      "$ref": "#/$defs/RedactionPolicy"
    },
    "signature": {
      "anyOf": [
        {
          "$ref": "#/$defs/Signature"
        },
        {
          "type": "null"
        }
      ]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Vendor extensions. Extensions MUST NOT alter the meaning of required fields."
    }
  },
  "$defs": {
    "MessageType": {
      "type": "string",
      "enum": [
        "service.manifest.published",
        "service.heartbeat",
        "service.degraded",
        "service.retired",
        "service.capability.changed",
        "intent.submitted",
        "user.message",
        "voice.segment.created",
        "voice.transcript.candidate",
        "voice.intent.candidate",
        "attention.candidate",
        "attention.packet.created",
        "attention.escalation.created",
        "attention.receipt.recorded",
        "approval.requested",
        "approval.decision.recorded",
        "work_order.created",
        "work_order.updated",
        "workflow.graph.created",
        "workflow.graph.updated",
        "workflow.graph.closed",
        "task.created",
        "task.commanded",
        "task.state.changed",
        "task.progress.reported",
        "task.blocked",
        "task.unblocked",
        "task.cancel.requested",
        "task.rollback.requested",
        "task.completed",
        "task.failed",
        "task.quarantined",
        "lease.requested",
        "lease.issued",
        "lease.denied",
        "lease.renewed",
        "lease.revoked",
        "lease.expired",
        "context.contract.granted",
        "context.contract.revoked",
        "tool.manifest.published",
        "tool.audit.requested",
        "tool.audit.result",
        "tool.call.requested",
        "tool.call.authorized",
        "tool.call.denied",
        "tool.call.result",
        "tool.build.proposed",
        "tool.build.plan.created",
        "tool.build.result",
        "tool.deprecated",
        "tool.decommissioned",
        "data.asset.registered",
        "data.asset.updated",
        "data.access.requested",
        "data.access.granted",
        "data.access.denied",
        "data.observation.recorded",
        "evidence.bundle.created",
        "evidence.item.appended",
        "evidence.verification.requested",
        "evidence.verification.result",
        "evidence.challenge.created",
        "policy.decision.recorded",
        "policy.violation.detected",
        "fault.detected",
        "incident.created",
        "incident.updated",
        "incident.resolved",
        "memory.candidate.created",
        "memory.proposal.created",
        "memory.accepted",
        "memory.rejected",
        "memory.revoked",
        "knowledge.compression.result",
        "self_improvement.proposed",
        "self_improvement.experiment.started",
        "self_improvement.experiment.result",
        "self_improvement.canary.started",
        "self_improvement.deployed",
        "self_improvement.rollback.requested",
        "self_improvement.rolled_back",
        "research.query.created",
        "research.result.recorded",
        "model.route.requested",
        "model.eval.result",
        "budget.event.recorded",
        "cost.event.recorded",
        "telemetry.emitted",
        "conformance.result.recorded"
      ]
    },
    "PrincipalRef": {
      "type": "object",
      "required": [
        "principal_id"
      ],
      "additionalProperties": false,
      "properties": {
        "principal_id": {
          "type": "string"
        },
        "service_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Principal": {
      "type": "object",
      "required": [
        "principal_id",
        "service_id",
        "instance_id",
        "trust_tier"
      ],
      "additionalProperties": false,
      "properties": {
        "principal_id": {
          "type": "string"
        },
        "service_id": {
          "type": "string"
        },
        "instance_id": {
          "type": "string"
        },
        "service_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "code_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(sha256:[a-fA-F0-9]{64})?$"
        },
        "trust_tier": {
          "type": "string",
          "enum": [
            "root-authority",
            "core-service",
            "trusted-adapter",
            "quarantined-adapter",
            "worker",
            "external-agent",
            "human-user",
            "voice-surface",
            "test-fixture"
          ]
        },
        "auth_context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "TraceContext": {
      "type": "object",
      "required": [
        "trace_id"
      ],
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "span_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "parent_span_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "correlation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "causation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "intent_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "work_order_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflow_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "attempt_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "replay_epoch": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "DeliverySemantics": {
      "type": "object",
      "required": [
        "class",
        "idempotency_key"
      ],
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "D0-ephemeral",
            "D1-at-most-once",
            "D2-at-least-once",
            "D3-effectively-once",
            "D4-authority-serialized"
          ]
        },
        "ordering_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "dedupe_window_seconds": {
          "type": "integer",
          "minimum": 0,
          "default": 86400
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "default": 3
        },
        "ack_required": {
          "type": "boolean",
          "default": true
        },
        "dead_letter_subject": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "RiskContext": {
      "type": "object",
      "required": [
        "risk_tier",
        "autonomy_tier",
        "criticality",
        "silence_risk"
      ],
      "additionalProperties": false,
      "properties": {
        "risk_tier": {
          "type": "string",
          "enum": [
            "R0-readonly",
            "R1-local-draft",
            "R2-repo-draft",
            "R3-cross-repo",
            "R4-production-or-secret",
            "R5-policy-or-memory",
            "R6-self-modifying-authority"
          ]
        },
        "autonomy_tier": {
          "type": "string",
          "enum": [
            "A0-human-only",
            "A1-suggest",
            "A2-draft",
            "A3-act-with-lease",
            "A4-act-with-proof",
            "A5-shadow-or-canary-only"
          ]
        },
        "criticality": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "blast_radius": {
          "type": "string",
          "enum": [
            "none",
            "local",
            "repo",
            "cross-repo",
            "user-data",
            "production",
            "organization",
            "authority-kernel"
          ]
        },
        "reversibility": {
          "type": "string",
          "enum": [
            "trivial",
            "easy",
            "moderate",
            "hard",
            "irreversible",
            "unknown"
          ]
        },
        "silence_risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "requires_user_approval": {
          "type": "boolean",
          "default": false
        },
        "requires_quorum": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "DataClassification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "secret",
        "regulated",
        "credential",
        "unknown"
      ]
    },
    "PolicyContext": {
      "type": "object",
      "required": [
        "policy_epoch"
      ],
      "additionalProperties": false,
      "properties": {
        "policy_epoch": {
          "type": "string"
        },
        "policy_bundle_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "ruleset_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "simulation_required": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "SchemaRef": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "content_type": {
          "type": "string",
          "default": "application/schema+json"
        }
      }
    },
    "RedactionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "classification_floor": {
          "$ref": "#/$defs/DataClassification"
        },
        "allowed_views": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "retention_class": {
          "type": "string",
          "enum": [
            "ephemeral",
            "short",
            "standard",
            "long",
            "legal-hold",
            "do-not-store"
          ],
          "default": "standard"
        },
        "secret_scan_required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "Signature": {
      "type": "object",
      "required": [
        "scheme",
        "key_id",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "scheme": {
          "type": "string",
          "enum": [
            "JWS",
            "DSSE",
            "SigstoreBundle",
            "DetachedEd25519",
            "DetachedECDSA"
          ]
        },
        "alg": {
          "type": [
            "string",
            "null"
          ]
        },
        "key_id": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        },
        "signed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "all"
          ]
        },
        "certificate_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TaskKind": {
      "type": "string",
      "enum": [
        "investigate",
        "bug_fix",
        "feature",
        "refactor",
        "security_review",
        "incident_response",
        "repo_creation",
        "research",
        "knowledge_compression",
        "memory_promotion",
        "tool_build",
        "tool_audit",
        "self_improvement",
        "data_ingestion",
        "telemetry_analysis",
        "test_generation",
        "dependency_update",
        "performance_optimization",
        "cost_reduction",
        "user_followup",
        "policy_change",
        "migration",
        "release",
        "rollback",
        "documentation",
        "prototype",
        "sandbox_experiment",
        "deprecation",
        "scheduled_maintenance",
        "audit",
        "red_team",
        "model_eval",
        "unknown"
      ]
    },
    "TaskState": {
      "type": "string",
      "enum": [
        "proposed",
        "triaged",
        "planned",
        "leased",
        "dispatched",
        "running",
        "waiting_for_evidence",
        "waiting_for_user",
        "blocked",
        "paused",
        "reviewing",
        "verifying",
        "ready_to_promote",
        "promoting",
        "completed",
        "failed",
        "canceled",
        "rolled_back",
        "quarantined"
      ]
    },
    "Budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_usd": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "max_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "max_wall_clock_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "max_cpu_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "max_io_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "max_parallelism": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "WorkOrder": {
      "type": "object",
      "required": [
        "work_order_id",
        "title",
        "origin",
        "objective",
        "risk_tier",
        "status",
        "tasks"
      ],
      "additionalProperties": false,
      "properties": {
        "work_order_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "origin": {
          "type": "string",
          "enum": [
            "human-text",
            "human-voice",
            "system-detected",
            "scheduled",
            "incident",
            "self-improvement",
            "tool-radar",
            "external-webhook"
          ]
        },
        "objective": {
          "type": "string"
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "risk_tier": {
          "$ref": "#/$defs/RiskContext"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "active",
            "waiting",
            "blocked",
            "completed",
            "failed",
            "canceled"
          ]
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Task"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "budget": {
          "$ref": "#/$defs/Budget"
        },
        "attention_policy": {
          "$ref": "#/$defs/AttentionPolicy"
        }
      }
    },
    "Task": {
      "type": "object",
      "required": [
        "task_id",
        "kind",
        "state",
        "title",
        "owner",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/TaskKind"
        },
        "state": {
          "$ref": "#/$defs/TaskState"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner": {
          "$ref": "#/$defs/PrincipalRef"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "lease_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "evidence_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "rollback_plan_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "budget": {
          "$ref": "#/$defs/Budget"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0
        }
      }
    },
    "WorkflowGraph": {
      "type": "object",
      "required": [
        "workflow_id",
        "nodes",
        "edges"
      ],
      "additionalProperties": false,
      "properties": {
        "workflow_id": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Task"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "to",
              "type"
            ],
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "depends_on",
                  "blocks",
                  "verifies",
                  "rolls_back",
                  "supersedes",
                  "duplicates",
                  "fanout",
                  "fanin"
                ]
              }
            }
          }
        },
        "wip_limit": {
          "type": "integer",
          "minimum": 1,
          "default": 8
        },
        "scheduler": {
          "type": "string",
          "enum": [
            "priority-fair",
            "deadline-first",
            "risk-first",
            "cost-aware",
            "manual"
          ],
          "default": "priority-fair"
        }
      }
    },
    "CapabilityLease": {
      "type": "object",
      "required": [
        "lease_id",
        "principal",
        "capabilities",
        "scope",
        "issued_at",
        "expires_at",
        "policy_epoch"
      ],
      "additionalProperties": false,
      "properties": {
        "lease_id": {
          "type": "string"
        },
        "principal": {
          "$ref": "#/$defs/PrincipalRef"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "scope": {
          "type": "object",
          "additionalProperties": true
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "max_uses": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "remaining_uses": {
