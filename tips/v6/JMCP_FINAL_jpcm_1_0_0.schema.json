{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.jmcp.dev/jpcm/1.0.0/envelope.schema.json",
  "title": "JPCM-1.0.0 Joint Process Control Messaging Envelope and Payload Schema",
  "description": "Normative schema for the JMCP/JPCM control protocol. All services, tools, agents, UIs, voice adapters, data adapters, and self-improvement workers MUST communicate with JMCP using this envelope or a semantically equivalent negotiated binding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jpcm_version",
    "id",
    "type",
    "subject",
    "time",
    "source",
    "producer",
    "tenant",
    "cell",
    "trace",
    "correlation_id",
    "actor",
    "authority",
    "risk",
    "privacy",
    "delivery",
    "schema_ref",
    "payload_hash",
    "signature",
    "payload"
  ],
  "properties": {
    "jpcm_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "UUIDv7 or ULID. Globally unique and immutable."
    },
    "type": {
      "type": "string",
      "enum": [
        "service.card.published",
        "service.heartbeat",
        "service.health.reported",
        "service.degraded",
        "service.quarantined",
        "service.conformance.reported",
        "user.intent.submitted",
        "user.intent.updated",
        "user.intent.cancel_requested",
        "user.decision.submitted",
        "user.preference.updated",
        "attention.candidate",
        "attention.escalation",
        "attention.summary",
        "attention.decision_required",
        "attention.suppressed",
        "attention.resolved",
        "voice.session.started",
        "voice.segment.transcribed",
        "voice.command.candidate",
        "voice.confirmation.required",
        "voice.confirmation.accepted",
        "voice.confirmation.rejected",
        "voice.session.ended",
        "text.message.received",
        "text.message.sent",
        "work_order.created",
        "work_order.planned",
        "work_order.approved",
        "work_order.started",
        "work_order.paused",
        "work_order.resumed",
        "work_order.completed",
        "work_order.failed",
        "work_order.cancelled",
        "work_order.quarantined",
        "work_order.rolled_back",
        "task.created",
        "task.scheduled",
        "task.dispatched",
        "task.claimed",
        "task.progress",
        "task.blocked",
        "task.awaiting_evidence",
        "task.awaiting_approval",
        "task.completed",
        "task.failed",
        "task.cancelled",
        "task.quarantined",
        "task.rollback_requested",
        "task.rolled_back",
        "lease.requested",
        "lease.issued",
        "lease.renewed",
        "lease.revoked",
        "lease.expired",
        "lease.denied",
        "lease.used",
        "context.requested",
        "context.granted",
        "context.revoked",
        "context.used",
        "context.leaked_detected",
        "tool.card.published",
        "tool.call.requested",
        "tool.call.authorized",
        "tool.call.started",
        "tool.call.result",
        "tool.call.denied",
        "tool.call.failed",
        "tool.call.cancelled",
        "data.card.published",
        "data.query.requested",
        "data.query.authorized",
        "data.query.result",
        "data.query.denied",
        "data.mutation.requested",
        "data.mutation.authorized",
        "data.mutation.result",
        "data.mutation.denied",
        "evidence.claimed",
        "evidence.appended",
        "evidence.verified",
        "evidence.rejected",
        "evidence.conflict.detected",
        "promotion.requested",
        "promotion.approved",
        "promotion.denied",
        "promotion.executed",
        "rollback.started",
        "rollback.completed",
        "rollback.failed",
        "policy.decision",
        "policy.veto.issued",
        "policy.waiver.requested",
        "policy.waiver.granted",
        "policy.waiver.denied",
        "policy.updated",
        "memory.proposal",
        "memory.accepted",
        "memory.rejected",
        "memory.compacted",
        "memory.tombstoned",
        "memory.poisoning.detected",
        "experience.event",
        "reflection.report",
        "technology.inventory.reported",
        "technology.scout.finding",
        "technology.gap.detected",
        "technology.build.proposal",
        "technology.build.started",
        "technology.build.result",
        "technology.build.promoted",
        "technology.build.rejected",
        "self_improvement.proposal",
        "self_improvement.experiment_started",
        "self_improvement.evaluation_result",
        "self_improvement.promoted",
        "self_improvement.rejected",
        "self_improvement.rollback",
        "incident.opened",
        "incident.updated",
        "incident.mitigated",
        "incident.closed",
        "incident.postmortem.published",
        "audit.checkpoint",
        "audit.exported",
        "audit.tamper_detected"
      ]
    },
    "subject": {
      "type": "string",
      "pattern": "^jpcm(\\.[a-z0-9_-]+)+$",
      "description": "Hierarchical routing subject. Example: jpcm.task.event.repo.<repo_id>.<work_order_id>."
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "description": "Logical service or adapter URI, e.g., service:jeryu.git or ui:web-cockpit."
    },
    "producer": {
      "$ref": "#/$defs/Principal"
    },
    "tenant": {
      "type": "string"
    },
    "cell": {
      "type": "string",
      "description": "Control cell or deployment cell. Used for blast-radius isolation."
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "test",
        "staging",
        "prod",
        "incident",
        "lab"
      ],
      "default": "prod"
    },
    "trace": {
      "$ref": "#/$defs/TraceContext"
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "stream": {
      "$ref": "#/$defs/StreamPosition"
    },
    "actor": {
      "$ref": "#/$defs/Actor"
    },
    "authority": {
      "$ref": "#/$defs/AuthorityContext"
    },
    "risk": {
      "$ref": "#/$defs/RiskContext"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyContext"
    },
    "delivery": {
      "$ref": "#/$defs/DeliveryContext"
    },
    "ordering_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "dedupe_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_ref": {
      "type": "string",
      "description": "Canonical schema id for payload."
    },
    "payload_hash": {
      "$ref": "#/$defs/Digest"
    },
    "signature": {
      "$ref": "#/$defs/Signature"
    },
    "payload": {
      "$ref": "#/$defs/JpcmPayload"
    }
  },
  "$defs": {
    "Digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "enum": [
            "sha256",
            "sha512",
            "blake3"
          ]
        },
        "value": {
          "type": "string"
        }
      }
    },
    "Signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "kid",
        "value",
        "covered_fields"
      ],
      "properties": {
        "alg": {
          "enum": [
            "Ed25519",
            "ES256",
            "RS256",
            "DSSE-Ed25519",
            "JWS-Ed25519"
          ]
        },
        "kid": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "covered_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "certificate_chain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rekor_entry": {
          "type": "string"
        }
      }
    },
    "Principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "trust_domain"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "human",
            "service",
            "agent",
            "tool",
            "adapter",
            "model",
            "scheduler",
            "policy_engine",
            "ui",
            "voice_gateway"
          ]
        },
        "trust_domain": {
          "type": "string"
        },
        "spiffe_id": {
          "type": "string"
        },
        "public_key_ref": {
          "type": "string"
        },
        "attestation_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "actor_kind",
        "display_name"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_kind": {
          "enum": [
            "human",
            "jmcp",
            "agent",
            "service",
            "tool",
            "model",
            "external_system",
            "scheduled_policy"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "on_behalf_of": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TraceContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "span_id"
      ],
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "span_id": {
          "type": "string"
        },
        "parent_span_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "traceparent": {
          "type": "string"
        },
        "tracestate": {
          "type": "string"
        }
      }
    },
    "StreamPosition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stream_id": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "consumer": {
          "type": "string"
        },
        "partition": {
          "type": "string"
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "AuthorityContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "mode",
        "lease_ids",
        "policy_version",
        "allowed"
      ],
      "properties": {
        "decision_id": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "observe_only",
            "draft_only",
            "sandbox_execute",
            "repo_branch",
            "pr_only",
            "guarded_merge",
            "production_mutation",
            "self_modify_proposal_only"
          ]
        },
        "lease_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_version": {
          "type": "string"
        },
        "allowed": {
          "type": "boolean"
        },
        "requires_human": {
          "type": "boolean"
        },
        "required_evidence_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceClass"
          }
        },
        "veto_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budget_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RiskContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "score",
        "blast_radius",
        "reversibility"
      ],
      "properties": {
        "tier": {
          "enum": [
            "r0_observe",
            "r1_reversible_local",
            "r2_repo_change",
            "r3_external_side_effect",
            "r4_security_or_money",
            "r5_irreversible_or_legal",
            "r6_self_modifying_control_plane"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blast_radius": {
          "enum": [
            "single_file",
            "repo",
            "org",
            "external_service",
            "customer",
            "production",
            "control_plane",
            "unknown"
          ]
        },
        "reversibility": {
          "enum": [
            "trivial",
            "rollback_available",
            "manual_repair",
            "hard",
            "irreversible",
            "unknown"
          ]
        },
        "novelty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "uncertainty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "safety_case_required": {
          "type": "boolean"
        }
      }
    },
    "PrivacyContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_classes",
        "retention",
        "purpose"
      ],
      "properties": {
        "data_classes": {
          "type": "array",
          "items": {
            "enum": [
              "public",
              "internal",
              "confidential",
              "secret",
              "credential",
              "regulated",
              "personal",
              "customer"
            ]
          }
        },
        "retention": {
          "enum": [
            "transient",
            "work_order",
            "audit",
            "legal_hold",
            "delete_after_session"
          ]
        },
        "purpose": {
          "type": "string"
        },
        "redaction_policy": {
          "type": "string"
        },
        "egress_allowed": {
          "type": "boolean"
        }
      }
    },
    "DeliveryContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "ack_required",
        "retry_policy"
      ],
      "properties": {
        "class": {
          "enum": [
            "ephemeral",
            "durable",
            "command",
            "audit",
            "evidence",
            "attention",
            "voice_realtime"
          ]
        },
        "ack_required": {
          "type": "boolean"
        },
        "retry_policy": {
          "$ref": "#/$defs/RetryPolicy"
        },
        "ttl_ms": {
          "type": "integer",
          "minimum": 0
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "backpressure_group": {
          "type": "string"
        }
      }
    },
    "RetryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "initial_backoff_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_backoff_ms": {
          "type": "integer",
          "minimum": 0
        },
        "jitter": {
          "type": "boolean"
        },
        "dead_letter_subject": {
          "type": "string"
        }
      }
    },
    "EvidenceClass": {
      "type": "string",
      "enum": [
        "unit_test",
        "integration_test",
        "e2e_test",
        "static_analysis",
        "security_scan",
        "typecheck",
        "lint",
        "build",
        "benchmark",
        "diff",
        "review",
        "policy_receipt",
        "provenance",
        "attestation",
        "replay",
        "screenshot",
        "human_approval",
        "runtime_trace",
        "rollback_plan",
        "data_lineage",
        "cost_receipt",
        "other"
      ]
    },
    "Money": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "currency"
      ],
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "Reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "uri"
      ],
      "properties": {
        "kind": {
          "enum": [
            "artifact",
            "commit",
            "pr",
            "issue",
            "run",
            "log",
            "trace",
            "metric",
            "span",
            "object",
            "schema",
            "policy",
            "memory",
            "doc",
            "url",
            "file",
            "ticket"
          ]
        },
        "uri": {
          "type": "string"
        },
        "digest": {
          "$ref": "#/$defs/Digest"
        },
        "media_type": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "ResourceScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource_kind",
        "resource_id",
        "permissions"
      ],
      "properties": {
        "resource_kind": {
          "enum": [
            "repo",
            "branch",
            "file",
            "directory",
            "database",
            "table",
            "bucket",
            "object",
            "api",
            "tool",
            "model",
            "secret",
            "ci",
            "cloud_account",
            "ui",
            "voice_session",
            "control_plane",
            "memory_store",
            "knowledge_graph",
            "network"
          ]
        },
        "resource_id": {
          "type": "string"
        },
        "permissions": {
          "type": "array",
          "items": {
            "enum": [
              "read",
              "search",
              "write",
              "delete",
              "execute",
              "network",
              "publish",
              "merge",
              "deploy",
              "approve",
              "mutate_policy",
              "mutate_memory",
              "build_tool",
              "self_modify"
            ]
          },
          "minItems": 1
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "BaseTaskRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "work_order_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "parent_task_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "repo_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ServiceCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_id",
        "name",
        "version",
        "kind",
        "owner",
        "capabilities",
        "endpoints",
        "schemas",
        "trust"
      ],
      "properties": {
        "service_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "jmcp_core",
            "adapter",
            "agent",
            "tool",
            "datastore",
            "ui",
            "voice_gateway",
            "policy_engine",
            "scheduler",
            "evidence_verifier",
            "repo_system",
            "ci",
            "model_router"
          ]
        },
        "owner": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "transport",
              "address"
            ],
            "properties": {
              "transport": {
                "enum": [
                  "nats",
                  "grpc",
                  "http",
                  "websocket",
                  "sse",
                  "webrtc",
                  "stdio",
                  "mcp",
                  "a2a",
                  "cli"
                ]
              },
              "address": {
                "type": "string"
              },
              "auth": {
                "type": "string"
              }
            }
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trust": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trust_level",
            "attestation_required"
          ],
          "properties": {
            "trust_level": {
              "enum": [
                "untrusted",
                "probation",
                "trusted_for_scope",
                "core",
                "quarantined"
              ]
            },
            "attestation_required": {
              "type": "boolean"
            },
            "last_conformance_report": {
              "type": "string"
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ToolCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_id",
        "name",
        "version",
        "owner",
        "input_schema",
        "output_schema",
        "side_effects",
        "risk_tier",
        "leases_required"
      ],
      "properties": {
        "tool_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "input_schema": {
          "type": "string"
        },
        "output_schema": {
          "type": "string"
        },
        "side_effects": {
          "type": "array",
          "items": {
            "enum": [
              "none",
              "filesystem",
              "network",
              "database",
              "git",
              "ci",
              "cloud",
              "money",
              "credential",
              "policy",
              "memory",
              "control_plane"
            ]
          }
        },
        "risk_tier": {
          "enum": [
            "r0_observe",
            "r1_reversible_local",
            "r2_repo_change",
            "r3_external_side_effect",
            "r4_security_or_money",
            "r5_irreversible_or_legal",
            "r6_self_modifying_control_plane"
          ]
        },
        "leases_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dry_run_supported": {
          "type": "boolean"
        },
