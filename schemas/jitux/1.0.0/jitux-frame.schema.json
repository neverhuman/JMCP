{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.neverhuman.ai/jmcp/jitux/1.0.0/jitux-frame.schema.json",
  "title": "JITUX/1.0.0 Mission Deck Frame Schema",
  "description": "Ephemeral UI-safe frame contract for JMCP Mission Deck sessions. Frames describe observable projections, panes, evidence, rank reasons, and prepared actions; they must not carry hidden reasoning, secrets, or approval tokens.",
  "type": "object",
  "required": [
    "v",
    "type",
    "sessionId",
    "seq",
    "frameId",
    "emittedAt",
    "source"
  ],
  "additionalProperties": true,
  "properties": {
    "v": {
      "const": 1
    },
    "type": {
      "enum": [
        "deck.patch",
        "pane.prepare",
        "pane.upsert",
        "pane.commit",
        "focus.change",
        "deck.rank.changed",
        "card.ghost",
        "card.commit",
        "card.hydrated",
        "evidence.attach",
        "action.ready",
        "session.done",
        "session.error"
      ]
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "frameId": {
      "type": "string",
      "minLength": 1
    },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "enum": [
        "frontend",
        "projection",
        "agent",
        "adapter",
        "replay",
        "approval"
      ]
    },
    "ttlMs": {
      "type": "integer",
      "minimum": 0
    },
    "pane": {
      "$ref": "#/$defs/PaneVM"
    },
    "reason": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/RankReason"
        }
      ]
    },
    "deck": {
      "type": "object"
    },
    "paneId": {
      "type": "string"
    },
    "orderedPaneIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      }
    },
    "action": {
      "$ref": "#/$defs/PreparedAction"
    },
    "error": {
      "type": "object"
    }
  },
  "$defs": {
    "PaneVM": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "title",
        "rank",
        "risk",
        "status",
        "lod",
        "confidence",
        "preview",
        "preparedTabs"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "queue",
            "jeryu",
            "jailgun",
            "jekko",
            "evidence",
            "replay",
            "approval",
            "adapter_health",
            "memory",
            "autonomy"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "rank": {
          "type": "number"
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "status": {
          "enum": [
            "predicted",
            "incubating",
            "warm",
            "active",
            "stale",
            "discarded"
          ]
        },
        "lod": {
          "enum": [
            "ghost",
            "preview",
            "focus"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshnessMs": {
          "type": "integer",
          "minimum": 0
        },
        "preview": {
          "type": "object",
          "required": [
            "headline",
            "chips",
            "counters"
          ],
          "additionalProperties": false,
          "properties": {
            "headline": {
              "type": "string"
            },
            "chips": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "counters": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "label",
                  "value"
                ],
                "additionalProperties": false,
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "type": [
                      "integer",
                      "string"
                    ]
                  }
                }
              }
            }
          }
        },
        "preparedTabs": {
          "type": "array",
          "items": {
            "enum": [
              "evidence",
              "replay",
              "systems",
              "actions",
              "raw"
            ]
          }
        }
      }
    },
    "RankReason": {
      "type": "object",
      "required": [
        "score",
        "factors",
        "explanation"
      ],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number"
        },
        "factors": {
          "type": "object",
          "required": [
            "risk",
            "blockedness",
            "approvalExpiryPressure",
            "leasePressure",
            "adapterDegradedWeight",
            "evidenceGapWeight",
            "userQueryRelevance",
            "freshness",
            "downstreamBlastRadius"
          ],
          "properties": {
            "risk": {
              "type": "number"
            },
            "blockedness": {
              "type": "number"
            },
            "approvalExpiryPressure": {
              "type": "number"
            },
            "leasePressure": {
              "type": "number"
            },
            "adapterDegradedWeight": {
              "type": "number"
            },
            "evidenceGapWeight": {
              "type": "number"
            },
            "userQueryRelevance": {
              "type": "number"
            },
            "freshness": {
              "type": "number"
            },
            "downstreamBlastRadius": {
              "type": "number"
            }
          }
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "EvidenceRef": {
      "type": "object",
      "required": [
        "id",
        "label",
        "uri",
        "capturedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "PreparedAction": {
      "type": "object",
      "required": [
        "id",
        "label",
        "command",
        "safety",
        "ready",
        "requiresApproval",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "safety": {
          "enum": [
            "read_only",
            "bounded_auto",
            "approval_required",
            "manual_only"
          ]
        },
        "ready": {
          "type": "boolean"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "previewRef": {
          "type": "string"
        }
      }
    }
  }
}
