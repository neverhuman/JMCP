{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.neverhuman.ai/jmcp/jcp/1.0.0/jcp.schema.json",
  "title": "JCP/1.0.0 Joint Control Protocol Schema",
  "description": "Canonical JSON Schema for the Joint Control Protocol used by all services, tools, agents, data adapters, UI surfaces, and voice gateways communicating with the Joint Master Control Plane (JMCP). JPCM is the recommended backbone profile that transports this envelope.",
  "type": "object",
  "required": [
    "jcp_version",
    "kind",
    "message_id",
    "message_type",
    "producer",
    "subject",
    "time",
    "trace",
    "authority",
    "policy",
    "data",
    "payload_hash",
    "payload",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "jcp_version": {
      "const": "1.0.0"
    },
    "kind": {
      "const": "JCPEnvelope"
    },
    "message_id": {
      "$ref": "#/$defs/UUIDLike"
    },
    "message_type": {
      "$ref": "#/$defs/MessageType"
    },
    "message_family": {
      "$ref": "#/$defs/MessageFamily"
    },
    "subject": {
      "$ref": "#/$defs/Subject"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "cell_id": {
      "type": "string",
      "minLength": 1,
      "description": "Deployment cell, trust zone, or autonomous work-cell identifier."
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "trace": {
      "$ref": "#/$defs/TraceContext"
    },
    "ordering": {
      "$ref": "#/$defs/Ordering"
    },
    "delivery": {
      "$ref": "#/$defs/Delivery"
    },
    "authority": {
      "$ref": "#/$defs/AuthorityContext"
    },
    "policy": {
      "$ref": "#/$defs/PolicyContext"
    },
    "risk": {
      "$ref": "#/$defs/RiskContext"
    },
    "attention": {
      "$ref": "#/$defs/AttentionContext"
    },
    "data": {
      "$ref": "#/$defs/DataContext"
    },
    "payload_schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "payload_hash": {
      "$ref": "#/$defs/Hash"
    },
    "payload": {
      "oneOf": [
        {
          "$ref": "#/$defs/Intent"
        },
        {
          "$ref": "#/$defs/WorkOrder"
        },
        {
          "$ref": "#/$defs/Task"
        },
        {
          "$ref": "#/$defs/TaskTransition"
        },
        {
          "$ref": "#/$defs/Command"
        },
        {
          "$ref": "#/$defs/CommandResult"
        },
        {
          "$ref": "#/$defs/ServiceCard"
        },
        {
          "$ref": "#/$defs/ToolCard"
        },
        {
          "$ref": "#/$defs/DataCard"
        },
        {
          "$ref": "#/$defs/AgentCard"
        },
        {
          "$ref": "#/$defs/CapabilityLease"
        },
        {
          "$ref": "#/$defs/ContextContract"
        },
        {
          "$ref": "#/$defs/EvidenceBundle"
        },
        {
          "$ref": "#/$defs/AttentionPacket"
        },
        {
          "$ref": "#/$defs/VoiceTurn"
        },
        {
          "$ref": "#/$defs/MemoryProposal"
        },
        {
          "$ref": "#/$defs/SelfImprovementProposal"
        },
        {
          "$ref": "#/$defs/ToolBuildProposal"
        },
        {
          "$ref": "#/$defs/PolicyDecision"
        },
        {
          "$ref": "#/$defs/PromotionDecision"
        },
        {
          "$ref": "#/$defs/FaultReport"
        },
        {
          "$ref": "#/$defs/TelemetrySignal"
        },
        {
          "$ref": "#/$defs/ConformanceReport"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "default": []
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "default": []
    },
    "redaction": {
      "$ref": "#/$defs/Redaction"
    },
    "encryption": {
      "$ref": "#/$defs/Encryption"
    },
    "signature": {
      "$ref": "#/$defs/Signature"
    },
    "signatures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Signature"
      },
      "default": []
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "UUIDLike": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{8,128}$",
      "description": "UUIDv7, ULID, or comparable globally unique identifier."
    },
    "Hash": {
      "type": "string",
      "pattern": "^(sha256|sha512|blake3):[A-Fa-f0-9]{32,128}$"
    },
    "Signature": {
      "type": "object",
      "required": [
        "alg",
        "kid",
        "value",
        "signed_at"
      ],
      "additionalProperties": false,
      "properties": {
        "alg": {
          "enum": [
            "ed25519",
            "ecdsa-p256-sha256",
            "rsa-pss-sha256",
            "sigstore-bundle",
            "jws-ed25519"
          ]
        },
        "kid": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signer_service_id": {
          "type": "string"
        },
        "signature_scope": {
          "enum": [
            "envelope",
            "payload",
            "envelope_and_payload",
            "artifact",
            "service_card"
          ]
        }
      }
    },
    "ArtifactRef": {
      "type": "object",
      "required": [
        "uri",
        "hash",
        "media_type"
      ],
      "additionalProperties": false,
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri-reference"
        },
        "hash": {
          "$ref": "#/$defs/Hash"
        },
        "media_type": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        },
        "retention_class": {
          "enum": [
            "ephemeral",
            "run",
            "audit",
            "legal_hold",
            "model_training_excluded"
          ]
        }
      }
    },
    "Subject": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "user",
            "intent",
            "work_order",
            "task",
            "run",
            "service",
            "tool",
            "agent",
            "data",
            "repo",
            "branch",
            "commit",
            "deployment",
            "voice_session",
            "memory",
            "policy",
            "evidence",
            "incident",
            "conformance"
          ]
        },
        "id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "Producer": {
      "type": "object",
      "required": [
        "service_id",
        "service_instance_id",
        "service_version",
        "service_card_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "service_id": {
          "type": "string"
        },
        "service_instance_id": {
          "type": "string"
        },
        "service_version": {
          "type": "string"
        },
        "service_card_hash": {
          "$ref": "#/$defs/Hash"
        },
        "spiffe_id": {
          "type": "string"
        },
        "accountable_owner": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        }
      }
    },
    "TraceContext": {
      "type": "object",
      "required": [
        "trace_id",
        "correlation_id",
        "idempotency_key"
      ],
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "span_id": {
          "type": "string"
        },
        "parent_span_id": {
          "type": "string"
        },
        "traceparent": {
          "type": "string"
        },
        "tracestate": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string"
        },
        "causation_id": {
          "type": "string"
        },
        "idempotency_key": {
          "type": "string"
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Ordering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stream": {
          "type": "string"
        },
        "partition_key": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "previous_message_hash": {
          "$ref": "#/$defs/Hash"
        },
        "requires_ordering": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "Delivery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "delivery_class": {
          "enum": [
            "ephemeral",
            "durable_at_least_once",
            "durable_ordered",
            "command_requires_ack",
            "audit_append_only"
          ]
        },
        "ack_deadline_ms": {
          "type": "integer",
          "minimum": 1
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0
        },
        "dead_letter_subject": {
          "type": "string"
        },
        "replay_policy": {
          "enum": [
            "none",
            "allowed_idempotent",
            "audit_only",
            "required_for_recovery"
          ]
        }
      }
    },
    "MessageFamily": {
      "enum": [
        "intent",
        "work_order",
        "task",
        "command",
        "lease",
        "context",
        "tool",
        "data",
        "agent",
        "evidence",
        "policy",
        "promotion",
        "attention",
        "voice",
        "memory",
        "self_improvement",
        "tool_build",
        "fault",
        "telemetry",
        "service",
        "audit",
        "conformance",
        "governance"
      ]
    },
    "MessageType": {
      "enum": [
        "intent.submitted",
        "intent.clarified",
        "intent.rejected",
        "intent.superseded",
        "work_order.proposed",
        "work_order.created",
        "work_order.updated",
        "work_order.paused",
        "work_order.resumed",
        "work_order.closed",
        "task.created",
        "task.state_changed",
        "task.blocked",
        "task.unblocked",
        "task.retry_scheduled",
        "task.cancel_requested",
        "task.canceled",
        "task.quarantined",
        "task.promoted",
        "task.rejected",
        "task.rolled_back",
        "command.requested",
        "command.accepted",
        "command.rejected",
        "command.result",
        "command.timeout",
        "command.compensated",
        "lease.requested",
        "lease.issued",
        "lease.renewed",
        "lease.revoked",
        "lease.expired",
        "lease.violation",
        "context.requested",
        "context.granted",
        "context.denied",
        "context.expired",
        "context.redacted",
        "tool.card.published",
        "tool.call.requested",
        "tool.call.result",
        "tool.call.denied",
        "tool.call.quarantined",
        "data.card.published",
        "data.query.requested",
        "data.query.result",
        "data.access.denied",
        "data.lineage.updated",
        "agent.card.published",
        "agent.delegation.requested",
        "agent.delegation.accepted",
        "agent.delegation.denied",
        "agent.result",
        "evidence.appended",
        "evidence.rejected",
        "evidence.sufficiency_assessed",
        "evidence.conflict_detected",
        "policy.decision",
        "policy.epoch_published",
        "policy.exception_requested",
        "policy.exception_decided",
        "promotion.requested",
        "promotion.approved",
        "promotion.rejected",
        "promotion.revoked",
        "attention.candidate",
        "attention.packet",
        "attention.escalation",
        "attention.resolution",
        "attention.false_quiet_alarm",
        "voice.segment",
        "voice.transcript",
        "voice.command_candidate",
        "voice.confirmation_requested",
        "voice.confirmed",
        "voice.rejected",
        "memory.proposed",
        "memory.accepted",
        "memory.rejected",
        "memory.decayed",
        "memory.contradiction_detected",
        "self_improvement.proposed",
        "self_improvement.approved",
        "self_improvement.shadow_started",
        "self_improvement.evaluated",
        "self_improvement.promoted",
        "self_improvement.reverted",
        "tool_build.proposed",
        "tool_build.specified",
        "tool_build.implemented",
        "tool_build.tested",
        "tool_build.quarantined",
        "tool_build.promoted",
        "tool_build.deprecated",
        "fault.detected",
        "fault.triaged",
        "fault.mitigated",
        "fault.postmortem",
        "fault.watchdog_veto",
        "telemetry.signal",
        "telemetry.slo_breach",
        "telemetry.cost_breach",
        "service.card_published",
        "service.heartbeat",
        "service.health_changed",
        "service.degraded",
        "service.decommissioned",
        "audit.recorded",
        "conformance.report",
        "governance.vote",
        "governance.freeze"
      ]
    },
    "RiskTier": {
      "enum": [
        "R0_observe",
        "R1_read_only",
        "R2_local_reversible",
        "R3_repo_write",
        "R4_external_side_effect",
        "R5_security_sensitive",
        "R6_financial_or_legal",
        "R7_irreversible_or_public"
      ]
    },
    "AutonomyTier": {
      "enum": [
        "A0_manual_only",
        "A1_suggest",
        "A2_prepare_for_review",
        "A3_execute_reversible",
        "A4_execute_with_guardrails",
        "A5_autonomous_low_risk",
        "A6_autonomous_with_audit",
        "A7_forbidden_without_explicit_user"
      ]
    },
    "DataClass": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "secret",
        "restricted",
        "credential",
        "personal",
        "regulated",
        "unknown"
      ]
    },
    "AttentionClass": {
      "enum": [
        "silent",
        "digest",
        "notify",
        "ask",
        "interrupt",
        "block_until_user",
        "emergency"
      ]
    },
    "AuthorityContext": {
      "type": "object",
      "required": [
        "lease_id",
        "authority_class",
        "permissions",
        "scope",
        "expires_at"
      ],
      "additionalProperties": false,
      "properties": {
        "lease_id": {
          "type": "string"
        },
        "lease_hash": {
          "$ref": "#/$defs/Hash"
        },
        "authority_class": {
          "enum": [
            "none",
            "read_context",
            "plan",
            "execute_sandbox",
            "write_repo",
            "run_ci",
            "access_secret",
            "deploy",
            "spend_budget",
            "contact_external",
            "change_policy",
            "self_improve",
            "build_tool"
          ]
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "max_risk_tier": {
          "$ref": "#/$defs/RiskTier"
        },
        "requires_user_approval": {
          "type": "boolean"
        },
        "break_glass": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "PolicyContext": {
      "type": "object",
      "required": [
        "policy_epoch",
        "decision_id"
      ],
      "additionalProperties": false,
      "properties": {
        "policy_epoch": {
          "type": "string"
        },
        "decision_id": {
          "type": "string"
        },
        "policy_hash": {
          "$ref": "#/$defs/Hash"
        },
        "engine": {
          "type": "string"
        },
        "allowed": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "obligations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RiskContext": {
      "type": "object",
      "required": [
        "risk_tier",
        "autonomy_tier"
      ],
      "additionalProperties": false,
      "properties": {
        "risk_tier": {
          "$ref": "#/$defs/RiskTier"
        },
        "autonomy_tier": {
          "$ref": "#/$defs/AutonomyTier"
        },
        "impact": {
          "type": "array",
          "items": {
            "enum": [
              "code_quality",
              "security",
              "privacy",
              "cost",
              "availability",
              "legal",
              "reputation",
              "data_integrity",
              "user_trust"
            ]
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "AttentionContext": {
      "type": "object",
      "required": [
        "attention_class"
      ],
      "additionalProperties": false,
      "properties": {
        "attention_class": {
          "$ref": "#/$defs/AttentionClass"
        },
        "user_visible": {
          "type": "boolean"
        },
        "minimum_packet_required": {
          "type": "boolean"
        },
        "false_quiet_check": {
          "type": "boolean"
        },
        "decision_deadline": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "DataContext": {
      "type": "object",
      "required": [
        "classification",
        "retention",
        "allowed_uses"
      ],
      "additionalProperties": false,
      "properties": {
        "classification": {
          "$ref": "#/$defs/DataClass"
        },
        "retention": {
          "enum": [
            "none",
            "ephemeral",
            "run",
            "project",
            "audit",
            "legal_hold"
          ]
        },
        "allowed_uses": {
          "type": "array",
          "items": {
            "enum": [
              "planning",
              "execution",
              "debugging",
              "evaluation",
              "memory_candidate",
              "training_excluded",
              "reporting",
              "legal_hold"
            ]
          }
        },
        "redaction_profile": {
          "type": "string"
        },
        "data_card_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contains_credentials": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "Redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string"
        },
        "redacted_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "Encryption": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "encrypted": {
          "type": "boolean"
        },
        "alg": {
          "type": "string"
        },
        "key_ref": {
          "type": "string"
        },
        "aad_hash": {
          "$ref": "#/$defs/Hash"
        }
      }
    },
    "Intent": {
      "type": "object",
      "required": [
        "intent_id",
        "submitted_by",
        "natural_language",
        "channel",
        "requested_outcome"
      ],
      "additionalProperties": true,
      "properties": {
        "intent_id": {
          "type": "string"
        },
        "submitted_by": {
          "type": "string"
        },
        "natural_language": {
          "type": "string"
        },
        "channel": {
          "enum": [
            "text",
            "voice",
            "api",
            "schedule",
            "system"
          ]
        },
        "requested_outcome": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "negative_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TaskKind": {
      "enum": [
        "research",
        "planning",
        "coding",
        "code_review",
        "test_generation",
        "ci_triage",
        "bug_fix",
        "refactor",
        "security_review",
        "dependency_update",
        "release",
        "deployment",
        "incident_response",
        "observability_analysis",
        "data_query",
        "knowledge_compression",
        "memory_maintenance",
        "tool_inventory",
        "tool_build",
        "self_improvement",
        "policy_update",
        "documentation",
        "user_communication",
        "voice_command",
        "external_agent_delegation",
        "governance",
        "cost_optimization",
        "architecture_design",
        "experiment",
        "benchmark",
        "conformance_test",
        "backup_restore",
        "migration",
        "legal_compliance",
        "unknown"
      ]
    },
    "WorkOrder": {
      "type": "object",
      "required": [
        "work_order_id",
        "objective",
        "owner",
        "status",
        "tasks",
        "success_criteria",
        "budgets"
      ],
      "additionalProperties": true,
      "properties": {
        "work_order_id": {
          "type": "string"
        },
        "parent_work_order_id": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "enum": [
            "proposed",
            "active",
            "paused",
            "blocked",
            "completed",
            "failed",
